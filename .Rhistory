#data summary and graph: day x secchi
mean_secchi <- secchi %>% group_by(Date) %>% summarise(AvgSec = mean(Secchi))
# make a ggplot
secchi_fig <- ggplot(mean_secchi, aes(x = Date, y = AvgSec)) + geom_bar(stat = 'identity', position = 'dodge') + geom_col(fill = "steelblue")
# convert to plotly
ggplotly(secchi_fig)
View(secchi)
#| label: Library
library(forcats)
library(kableExtra)
library(ggplot2)
library(jsonlite)
library(dplyr)
library(leaflet)
library(lubridate)
library(plotly)
library(tibble)
library(tidyverse)
library(gtsummary)
#| label: fig-map
#| fig-cap: "Map showing 2026 sampling area and proximity to AMIkids marina."
#| fig-align: "center"
df <- data.frame(
lng = c(-82.596, -82.614),
lat = c(27.854, 27.87),
site = c("2026 Sampling Area", "AMIkids Marina")
)
# Create the map using the data frame
df %>%
leaflet() %>%
addTiles() %>%
addMarkers(
lng = ~lng,
lat = ~lat,
popup = ~site, # Use the 'site' column for popups
) %>%
setView(lng = -82.605, lat = 27.866, zoom = 14)
#| label: fig-Secchi
#| fig-cap: "Secchi depths measured during 2026."
# create the secchi depth bar chart
secchi <- read.csv("https://github.com/GmangroveBari/Seagrass2026-AMIkids/blob/main/2026-WaterQualityData.csv")
#data summary and graph: day x secchi
mean_secchi <- secchi %>% group_by(Date) %>% summarise(AvgSec = mean(Secchi))
# make a ggplot
secchi_fig <- ggplot(mean_secchi, aes(x = Date, y = AvgSec)) + geom_bar(stat = 'identity', position = 'dodge') + geom_col(fill = "steelblue")
# convert to plotly
ggplotly(secchi_fig)
#| label: fig-depth
#| fig-cap: "Mean depths for 2026 sampling events."
#| fig-align: "center"
# create the avg depth bar chart
depth <- read.csv("https://raw.githubusercontent.com/GmangroveBari/SeagrassOctober2025/refs/heads/main/2026-AMIkidsSeagrassClasses.csv")
#data summary and graph: date, species, and abundance
Mean_Depth <- depth %>%
group_by(Date) %>%
summarise (AvgD = mean(Depth))
# make a ggplot
Depth_fig <- ggplot(Mean_Depth, aes(x = Date, y = AvgD)) +
geom_bar(stat = 'identity', position = 'dodge') + geom_col(fill = "ORANGE")
# convert to plotly
ggplotly(Depth_fig)
#| label: tbl-sed
#| tbl-cap: "Mean sediment scores for October 2025 sampling effort. Scores are objectively assessed  as follows: 1=Shelly sand, 2=Sand, 3=Muddy sand, 4=Mud, 5=Oysters."
sed <- read_csv("https://raw.githubusercontent.com/GmangroveBari/SeagrassOctober2025/refs/heads/main/2026-AMIkidsSeagrassClasses.csv", col_select = c(Day, SedimentType))
mean_sed <- sed %>%
group_by(Date) %>%
summarise('Sediment Score' = mean(SedimentType))
# Remove empty row
mean_sed <- mean_sed[-c(1), ]
# Generate a markdown table
knitr::kable(mean_sed, format = "html", align = "cc", digits = 1) %>%
kableExtra::kable_styling(full_width = FALSE, position = "left")
#| label: fig-BB
#| fig-cap: "Braun-Blanquet Coverage at Weedon Island in 2026."
Seagrass1 <- read.csv("https://raw.githubusercontent.com/GmangroveBari/SeagrassOctober2025/refs/heads/main/2026-AMIkidsSeagrassClasses.csv")
#data summary and graph: date, species, and abundance
mean_AbApp <- Seagrass1 %>%
group_by(Date, Species) %>%
summarise(AvgAbu = mean(Abundance), AvgApp = mean(Appearance))
#removing empty rows - no SAV observed
NoZeroAb <- mean_AbApp[apply(mean_AbApp!=0, 1, all),] %>%
drop_na(Date, Species, AvgAbu)
#plotting abundance data in grouped bar chart
NoZeroAb %>%
plot_ly(x = ~Date, y = ~AvgAbu, color = ~Species) %>%
add_bars() %>%
layout(barmode = "group",  xaxis = list(title = "Date", showgrid=T),
yaxis = list(title = "Braun-Blanquet Coverage"))
#| label: tbl-means
#| tbl-cap: "Overall averages for several different seagrass metrics assessed in 2026. Appearance and Epiphyte Density were scored on an objective scale from 1 (Excellent/None) to 5 (Poor/Heavy)."
Table2a <- read.csv("https://raw.githubusercontent.com/GmangroveBari/SeagrassOctober2025/refs/heads/main/2026-AMIkidsSeagrassClasses.csv")
# Create a custom summary table
summary_table <- Table2a %>%
group_by(Species) %>%
summarise(
n = n(), # Number of observations
Appearance = mean(Appearance, na.rm = TRUE),
EpiphtyDensity = mean(EpiphyteDensity, na.rm = TRUE),
ShootDensity = mean(ShtDen, na.rm = TRUE),
BladeLength = mean(AvgBld, na.rm = TRUE)
)
# Remove rows 1, 2, and 4
summary_table <- summary_table %>%
filter(!row_number() %in% c(4))
# rename columns 4-6
colnames(summary_table)[4] <- "Epiphyte Density"
colnames(summary_table)[5] <- "Shoots/m2"
colnames(summary_table)[6] <- "Blade Length (cm)"
# Generate a markdown table
knitr::kable(head(summary_table), digits = 1,  align = "lccccc")
#| label: fig-epiphyte
#| fig-cap: "Mean epiphyte density at Weedon Island in 2026."
Epiphyte <- read.csv("https://raw.githubusercontent.com/GmangroveBari/SeagrassOctober2025/refs/heads/main/2026-AMIkidsSeagrassClasses.csv")
#plotting epiphyte data in grouped bar chart
#data summary and graph: date, species, and abundance
Mean_Epi <- Epiphyte %>%
group_by(Date, Species) %>%
summarise(AvgEpi = mean(EpiphyteDensity))
Mean_Epi %>%
plot_ly(x = ~Date, y = ~AvgEpi, color = ~Species) %>%
add_bars() %>%
layout(barmode = "group", xaxis = list(title = "Date", showgrid=T),
yaxis = list(title = "Epiphyte density, graded from 1 (light) to 5 (heavy)"))
