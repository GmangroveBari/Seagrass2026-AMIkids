summarise(AvgAbu = mean(Abundance), AvgApp = mean(Appearance))
#removing empty rows - no SAV observed
NoZeroAb <- mean_AbApp[apply(mean_AbApp!=0, 1, all),] %>%
drop_na(Date, Species, AvgAbu)
#plotting abundance data in grouped bar chart
NoZeroAb %>%
plot_ly(x = ~Date, y = ~AvgAbu, color = ~Species) %>%
add_bars() %>%
layout(barmode = "group",  xaxis = list(title = "Date", showgrid=T),
yaxis = list(title = "Braun-Blanquet Coverage"))
#| label: fig-BB
#| fig-cap: "Braun-Blanquet Coverage at Weedon Island in 2026."
Seagrass1 <- read.csv("https://raw.githubusercontent.com/GmangroveBari/Seagrass2026-AMIkids/refs/heads/main/2026-AMIkidsSeagrassClasses.csv")
#data summary and graph: date, species, and abundance
mean_AbApp <- Seagrass1 %>%
group_by(Date, Species) %>%
summarise(AvgAbu = mean(Abundance), AvgApp = mean(Appearance))
#removing empty rows - no SAV observed
NoZeroAb <- mean_AbApp[apply(mean_AbApp!=0, 1, all),] %>%
drop_na(Date, Species, AvgAbu)
#plotting abundance data in grouped bar chart
NoZeroAb %>%
plot_ly(x = ~Date, y = ~AvgAbu, color = ~Species) %>%
add_bars() %>%
layout(barmode = "group",  xaxis = list(title = "Date", showgrid=T),
yaxis = list(title = "Braun-Blanquet Coverage"))
#| label: tbl-means
#| tbl-cap: "Overall averages for several different seagrass metrics assessed in 2026. Appearance and Epiphyte Density were scored on an objective scale from 1 (Excellent/None) to 5 (Poor/Heavy)."
Table2a <- read.csv("https://raw.githubusercontent.com/GmangroveBari/Seagrass2026-AMIkids/refs/heads/main/2026-AMIkidsSeagrassClasses.csv")
# Create a custom summary table
summary_table <- Table2a %>%
group_by(Species) %>%
summarise(
n = n(), # Number of observations
Appearance = mean(Appearance, na.rm = TRUE),
EpiphtyDensity = mean(EpiphyteDensity, na.rm = TRUE),
ShootDensity = mean(ShtDen, na.rm = TRUE),
BladeLength = mean(AvgBld, na.rm = TRUE)
)
# Remove rows 1, 2, and 4
summary_table <- summary_table %>%
filter(!row_number() %in% c(4))
# rename columns 4-6
colnames(summary_table)[4] <- "Epiphyte Density"
colnames(summary_table)[5] <- "Shoots/m2"
colnames(summary_table)[6] <- "Blade Length (cm)"
# Generate a markdown table
knitr::kable(head(summary_table), digits = 1,  align = "lccccc")
View(Table2a)
#| label: fig-epiphyte
#| fig-cap: "Mean epiphyte density at Weedon Island in 2026."
Epiphyte <- read.csv("https://raw.githubusercontent.com/GmangroveBari/Seagrass2026-AMIkids/refs/heads/main/2026-AMIkidsSeagrassClasses.csv")
#plotting epiphyte data in grouped bar chart
#data summary and graph: date, species, and abundance
Mean_Epi <- Epiphyte %>%
group_by(Date, Species) %>%
summarise(AvgEpi = mean(EpiphyteDensity))
Mean_Epi %>%
plot_ly(x = ~Date, y = ~AvgEpi, color = ~Species) %>%
add_bars() %>%
layout(barmode = "group", xaxis = list(title = "Date", showgrid=T),
yaxis = list(title = "Epiphyte density, graded from 1 (light) to 5 (heavy)"))
